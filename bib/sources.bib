% Заготовка базы источников для biblatex-gost.
%
% На текущем этапе библиография ведётся вручную в sections/bibliography.tex
% (см. комментарий в preamble.tex). Этот файл сохранён как точка старта на
% случай перехода к автоматизированной библиографии: переключить preamble
% на biblatex с style=gost-numeric и наполнить записями ниже.

% Пример книги (раскомментировать и заполнить):
% @book{atkinson2002mysql,
%   author    = {Аткинсон, Л.},
%   title     = {MySQL. Библиотека профессионала},
%   address   = {М.},
%   publisher = {Издательский дом <<Вильямс>>},
%   year      = {2002},
%   pages     = {624}
% }

% Пример статьи:
% @article{ivanov2025schedule,
%   author  = {Иванов, И. И. and Петров, П. П.},
%   title   = {Цифровизация управления учебным расписанием},
%   journal = {Информационные технологии в образовании},
%   year    = {2025},
%   number  = {3},
%   pages   = {12--34}
% }

% Пример онлайн-источника:
% @online{apple_hig,
%   author       = {{Apple Inc.}},
%   title        = {Human Interface Guidelines},
%   url          = {https://developer.apple.com/design/human-interface-guidelines},
%   urldate      = {2026-05-18}
% }
